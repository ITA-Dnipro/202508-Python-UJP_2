{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "extra_config": {
    "router": {
      "auto_options": true
    },
    "telemetry/logging": {
      "level": "DEBUG",
      "prefix": "[KRAKEND]",
      "syslog": false,
      "stdout": true,
      "format": "default"
    },
    "security/cors": {
      "allow_origins": ["*"],
      "allow_methods": ["GET", "POST", "PUT", "DELETE"],
      "expose_headers": ["Content-Length", "Content-Type", "Authorization"],
      "allow_headers": ["Accept-Language", "Authorization", "Content-Type"],
      "max_age": "12h",
      "allow_credentials": true,
      "debug": false
    }
  },
  "endpoints": [
    {
      "endpoint": "/api/users/auth/confirm-token/",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": ["*"],
      "backend": [
        {
          "url_pattern": "/api/users/auth/confirm-token/",
          "host": ["http://web:8000"],
          "method": "GET",
          "encoding": "json",
          "extra_config": {
            "proxy": {
              "flatmap_filter": []
            }
          }
        }
      ]
    },
    {
      "endpoint": "/api/users/auth/login/",
      "method": "POST",
      "output_encoding": "no-op",
      "input_headers": ["*"],
      "backend": [
        {
          "host": ["http://web:8000"],
          "url_pattern": "/api/users/auth/login/",
          "method": "POST",
          "encoding": "json",
          "extra_config": {
            "proxy": {
              "flatmap_filter": []
            }
          }
        }
      ]
    },
    {
      "endpoint": "/api/users/auth/registration/",
      "method": "POST",
      "output_encoding": "no-op",
      "input_headers": ["*"],
      "backend": [
        {
          "url_pattern": "/api/users/auth/registration/",
          "host": ["http://web:8000"],
          "method": "POST",
          "encoding": "json",
          "extra_config": {
            "proxy": {
              "flatmap_filter": []
            }
          }
        }
      ]
    },
    {
      "endpoint": "/api/{rest}",
      "method": "GET",
      "output_encoding": "no-op",
      "input_query_strings": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "HS256",
          "disable_jwk_security": true,
          "endpoint": "/api/users/auth/confirm-token/",
          "auth_header_name": "Authorization",
          "token_type": "Bearer",
          "propagate_claims": [
            ["role", "X-User-Role"],
            ["user_id", "X-User-Id"]
          ],
          "allow": ["*"]
        }
      },
      "backend": [
        {
          "url_pattern": "/api/{rest}",
          "host": ["http://web:8000"],
          "method": "GET",
          "encoding": "json",
          "is_collection": true,
          "allow": ["*"]
        }
      ]
    },
    {
      "endpoint": "/api/{rest}",
      "method": "POST",
      "output_encoding": "no-op",
      "input_query_strings": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "HS256",
          "disable_jwk_security": true,
          "endpoint": "/api/users/auth/confirm-token/",
          "auth_header_name": "Authorization",
          "token_type": "Bearer",
          "propagate_claims": [
            ["role", "X-User-Role"],
            ["user_id", "X-User-Id"]
          ],
          "allow": ["*"]
        }
      },
      "backend": [
        {
          "url_pattern": "/api/{rest}",
          "host": ["http://web:8000"],
          "method": "POST",
          "encoding": "json",
          "allow": ["*"]
        }
      ]
    },
    {
      "endpoint": "/api/{rest}",
      "method": "PUT",
      "output_encoding": "no-op",
      "input_query_strings": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "HS256",
          "disable_jwk_security": true,
          "endpoint": "/api/users/auth/confirm-token/",
          "auth_header_name": "Authorization",
          "token_type": "Bearer",
          "propagate_claims": [
            ["role", "X-User-Role"],
            ["user_id", "X-User-Id"]
          ],
          "allow": ["*"]
        }
      },
      "backend": [
        {
          "url_pattern": "/api/{rest}",
          "host": ["http://web:8000"],
          "method": "PUT",
          "encoding": "json",
          "allow": ["*"]
        }
      ]
    },
    {
      "endpoint": "/api/{rest}",
      "method": "DELETE",
      "output_encoding": "no-op",
      "input_query_strings": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "HS256",
          "disable_jwk_security": true,
          "endpoint": "/api/users/auth/confirm-token/",
          "auth_header_name": "Authorization",
          "token_type": "Bearer",
          "propagate_claims": [
            ["role", "X-User-Role"],
            ["user_id", "X-User-Id"]
          ],
          "allow": ["*"]
        }
      },
      "backend": [
        {
          "url_pattern": "/api/{rest}",
          "host": ["http://web:8000"],
          "method": "DELETE",
          "encoding": "json",
          "allow": ["*"]
        }
      ]
    },
    {
      "endpoint": "/chat/api/{rest}",
      "method": "POST",
      "output_encoding": "no-op",
      "input_query_strings": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "HS256",
          "disable_jwk_security": true,
          "endpoint": "/api/users/auth/confirm-token/",
          "auth_header_name": "Authorization",
          "token_type": "Bearer",
          "propagate_claims": [
            ["role", "X-User-Role"],
            ["user_id", "X-User-Id"]
          ],
          "allow": ["*"]
        }
      },
      "backend": [
        {
          "url_pattern": "/chat/api/{rest}",
          "host": ["http://web:8000"],
          "method": "POST",
          "encoding": "json",
          "allow": ["*"]
        }
      ]
    },
    {
      "endpoint": "/chat/",
      "method": "POST",
      "output_encoding": "no-op",
      "input_query_strings": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "HS256",
          "disable_jwk_security": true,
          "endpoint": "/api/users/auth/confirm-token/",
          "auth_header_name": "Authorization",
          "token_type": "Bearer",
          "propagate_claims": [
            ["role", "X-User-Role"],
            ["user_id", "X-User-Id"]
          ],
          "allow": ["*"]
        }
      },
      "backend": [
        {
          "url_pattern": "/chat/",
          "host": ["http://web:8000"],
          "method": "POST",
          "encoding": "json",
          "allow": ["*"]
        }
      ]
    }
  ],
  "timeout": "3s",
  "cache_ttl": "300s",
  "port": 8080
}