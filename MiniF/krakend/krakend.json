{
  "version": 3,
  "extra_config": {
    "router": {
      "auto_options": true
    },
    "telemetry/logging": {
      "level": "DEBUG",
      "prefix": "[KRAKEND]",
      "syslog": false,
      "stdout": true,
      "format": "default"
    },
    "security/cors": {
          "allow_origins": [
            "*"
          ],
          "allow_methods": [
            "GET",
            "POST",
            "DELETE"
          ],
          "expose_headers": [
            "Content-Length",
            "Content-Type",
            "Authorization"
          ],
          "allow_headers": [
            "Accept-Language",
            "Authorization",
            "Content-Type"
          ],
          "max_age": "12h",
          "allow_credentials": true,
          "debug": false
    }
  },
  "endpoints": [
    {
      "endpoint": "/api/users/{path}",
      "method": "GET",
      "output_encoding": "no-op",
      "extra_config": {
        "security/jwt": {
          "alg": "HS256",
          "secret": "${SECRET_KEY}",
          "roles_key": "role"
        }
      },
      "backend": [
        {
          "url_pattern": "/api/users/{path}",
          "host": ["http://web:8000"],
          "method": "GET",
          "encoding": "no-op",
          "whitelist": ["Authorization"],
          "allow": ["*"]
        }
      ]
    },
    {
      "endpoint": "/api/users/{path}",
      "method": "POST",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/api/users/{path}",
          "host": ["http://web:8000"],
          "method": "POST",
          "encoding": "no-op",
          "whitelist": ["Authorization"],
          "allow": ["*"]
        }
      ]
    },
    {
      "endpoint": "/api/users/{path}",
      "method": "PUT",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/api/users/{path}",
          "host": ["http://web:8000"],
          "method": "PUT",
          "encoding": "no-op",
          "whitelist": ["Authorization"],
          "allow": ["*"]
        }
      ]
    },
    {
