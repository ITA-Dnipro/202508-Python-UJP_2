{
  "version": 3,
  "extra_config": {
    "github_com/devopsfaith/krakend-cors": {
      "allow_origins": ["*"],
      "allow_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allow_headers": ["Origin", "Authorization", "Content-Type"]
    },
    "github_com/devopsfaith/krakend-ratelimit/jwt": {
      "max_rate": 100,
      "client_max_rate": 50
    },
    "github_com/devopsfaith/krakend-jwt-validator": {
      "secret": "$ENV:SECRET_KEY",
      "alg": "HS256"
    }
  },
  "endpoints": [
    {
      "endpoint": "/api/schema/swagger/",
      "method": "GET",
      "backend": [
        {
          "url_pattern": "/api/schema/swagger/",
          "host": ["http://web:8000"],
          "method": "GET"
        }
      ]
    },

    {
